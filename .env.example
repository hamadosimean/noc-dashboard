
# Database Configurations
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
POSTGRES_DB=db_name
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Cache Configurations
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL=300

# Backend Security
SECRET_KEY=secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Supervision tool integrations (real ETL collectors) ──────────────────
# A collector polls its tool every ETL_COLLECT_INTERVAL_S seconds, but ONLY
# when its *_API_URL is set — leave a URL empty to disable that collector.
# Hosts are matched to dim_node by code, then name, then IP address.

# Zabbix — JSON-RPC (e.g. https://zabbix.anptic.bf/api_jsonrpc.php)
ZABBIX_API_URL=
ZABBIX_USER=
ZABBIX_PASSWORD=
ZABBIX_API_TOKEN=            # Zabbix >= 5.4 API token; alternative to user/password

# Nagios — statusjson.cgi (e.g. https://nagios.anptic.bf/nagios)
NAGIOS_API_URL=
NAGIOS_USER=
NAGIOS_PASSWORD=
NAGIOS_API_KEY=              # sent as X-Auth-Token if set

# NetXMS — web API daemon (e.g. https://netxms.anptic.bf/rest)
NETXMS_API_URL=
NETXMS_USER=
NETXMS_PASSWORD=

# Centreon — REST API v2 (e.g. https://centreon.anptic.bf/centreon/api/latest)
# Centreon can ALSO push webhooks directly to POST /api/incidents/ingest.
CENTREON_API_URL=
CENTREON_USER=
CENTREON_PASSWORD=
CENTREON_API_KEY=            # static X-AUTH-TOKEN; alternative to user/password

#ITOP Integration
ITOP_URL=itop_url
ITOP_USER=itop_user
ITOP_PASS=itop_password

# NOC Dashboard API (static bearer key for supervision webhooks: Centreon/Zabbix -> /api/incidents/ingest)
NOC_API_KEY=change_me_api_key

# CORS - origins allowed to call the backend directly (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173

# Notifications (SMS Twilio + email SMTP on critical incidents)
NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
NOC_SMS_RECIPIENTS=+22670000000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noc@anptic.bf
NOC_EMAIL_RECIPIENTS=noc@anptic.bf

# Rate limiting (per IP, per minute — spec §10.1)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_READ_PER_MIN=100
RATE_LIMIT_INGEST_PER_MIN=10

# Materialized view: refresh synchronously on each write (demo) in addition to
# the nightly 02:00 ETL refresh. Set to false in production.
SYNC_MV_REFRESH=true

# Global Application Settings
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ETL / Celery
CELERY_BROKER_DB=1
# Batch poll interval for the supervision-tool collectors (spec §2.2: 5 min)
ETL_COLLECT_INTERVAL_S=300
