
# Database Configurations
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
POSTGRES_DB=db_name
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Cache Configurations
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL=300

# Backend Security
SECRET_KEY=secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Integrations (Zabbix, Centreon, Nagios)
ZABBIX_API_URL=zabbix_api_url
ZABBIX_USER=zabbix_user
ZABBIX_PASSWORD=zabbix_password

#ITOP Integration
ITOP_URL=itop_url
ITOP_USER=itop_user
ITOP_PASS=itop_password

# NOC Dashboard API (static bearer key for supervision webhooks: Centreon/Zabbix -> /api/incidents/ingest)
NOC_API_KEY=change_me_api_key

# CORS - origins allowed to call the backend directly (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173

# CENTREON Integration
CENTREON_API_URL=centreon_api_url
CENTREON_API_KEY=centreon_api_key

# NAGIOS Integration
NAGIOS_API_URL=nagios_api_url
NAGIOS_API_KEY=nagios_api_key

# Global Application Settings
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ETL / Celery
CELERY_BROKER_DB=1
ETL_COLLECT_INTERVAL_S=30
